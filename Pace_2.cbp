<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="Pace 2" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option platforms="Windows;" />
				<Option output="bin/Pace 2 dbg" prefix_auto="1" extension_auto="1" />
				<Option working_dir="bin" />
				<Option object_output="obj-pace/debug" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Option projectLinkerOptionsRelation="2" />
				<Compiler>
					<Add option="-Og" />
					<Add option="-Wall" />
					<Add option="-pg" />
					<Add option="-ggdb3" />
					<Add option="-Wno-unused" />
					<Add option="-DDEBUG" />
				</Compiler>
				<Linker>
					<Add option="-pg -lgmon" />
					<Add library="allegro_monolith-debug-static" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option platforms="Windows;" />
				<Option output="bin/Pace 2" prefix_auto="1" extension_auto="1" />
				<Option working_dir="bin" />
				<Option object_output="obj-pace" />
				<Option type="0" />
				<Option compiler="gcc" />
				<Option projectLinkerOptionsRelation="2" />
				<Compiler>
					<Add option="-O2" />
					<Add option="-DRELEASE" />
				</Compiler>
				<Linker>
					<Add option="-s" />
					<Add library="allegro_monolith-static" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-march=pentium4" />
			<Add option="-std=gnu11" />
			<Add option="-m32" />
			<Add option="-Werror" />
		</Compiler>
		<Linker>
