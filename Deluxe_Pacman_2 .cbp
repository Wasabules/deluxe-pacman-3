		<Unit filename="dp2_hiscore.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="dp2_hiscore.h" />
		<Unit filename="dp2_main.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="dp2_main.h">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="dp2_map.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="dp2_map.h" />
		<Unit filename="dp2_options.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="dp2_options.h" />
		<Unit filename="dp2_pacman.h">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="macros.h" />
		<Unit filename="resource.h">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="resource.rc">
			<Option compilerVar="WINDRES" />
		</Unit>
		<Unit filename="vec2d_stack.c">
			<Option compilerVar="CC" />
		</Unit>
